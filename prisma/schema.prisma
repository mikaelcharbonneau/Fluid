generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Users and authentication are managed by Supabase Auth (auth.users).
// Brand.userId stores the Supabase auth user UUID; ownership is enforced
// in the data-access layer (src/lib/db/brands.ts).
model Brand {
  id             String   @id @default(cuid())
  userId         String   @db.Uuid
  name           String
  about          String   @db.Text
  audience       String   @db.Text
  difference     String?  @db.Text
  competitors    String[]
  styleDirection String?
  strategy       Json
  selectedName   String?
  selectedStyle  String?
  selectedLogo   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}
