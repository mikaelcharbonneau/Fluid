# --- OpenAI (brand strategy agent) ---
# When unset, the API falls back to a deterministic demo strategy.
OPENAI_API_KEY=
# Set to "1" to disable OpenAI Agents tracing (recommended for privacy).
OPENAI_AGENTS_DISABLE_TRACING=

# --- Supabase (Postgres + Auth) ---
# Project URL and anon key from the Supabase dashboard (Project Settings > API).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Prisma connection strings to the Supabase Postgres database
# (Project Settings > Database > Connection string).
# Pooled (PgBouncer, port 6543) connection used at runtime.
DATABASE_URL=
# Direct (port 5432) connection used by `prisma migrate`.
DIRECT_URL=

# OAuth providers (GitHub, Google) are configured in the Supabase dashboard
# under Authentication > Providers — no client secrets are needed here.

# --- Rate limiting (Upstash Redis) ---
# When unset, per-user rate limiting on the brand-strategy endpoint is skipped.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Observability (Sentry, optional) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
