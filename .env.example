# --- OpenAI (brand strategy agent) ---
# When unset, the API falls back to a deterministic demo strategy.
OPENAI_API_KEY=
# Set to "1" to disable OpenAI Agents tracing (recommended for privacy).
OPENAI_AGENTS_DISABLE_TRACING=

# --- Database (Postgres, e.g. Neon / Vercel Postgres) ---
# Pooled connection used at runtime.
DATABASE_URL=
# Direct (non-pooled) connection used by `prisma migrate`.
DIRECT_URL=

# --- NextAuth ---
# Public URL of the app (e.g. http://localhost:3000 locally).
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Rate limiting (Upstash Redis) ---
# When unset, per-user rate limiting on the brand-strategy endpoint is skipped.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Observability (Sentry, optional) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
