# Copy to .env.local for local development.
#
# Phase 2 — auth + persistence (Supabase). Both values are safe to expose to
# the browser (they are the project URL and the publishable/"anon" key);
# row-level security is what protects data. Find them in the Supabase
# dashboard under Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Phase 3 — real generation (server-side only, never expose to the browser):
#   ANTHROPIC_API_KEY=
