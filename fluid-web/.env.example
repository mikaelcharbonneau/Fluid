# Copy to .env.local for local development.
#
# Phase 2 — auth + persistence (Supabase). These match the variables the
# Supabase↔Vercel integration provisions. Both are safe to expose to the
# browser (project URL + publishable key); row-level security protects data.
# Find them in the Supabase dashboard under Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Older projects may use this name instead; the app accepts either:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Phase 3 — real generation (server-side only, never expose to the browser):
#   ANTHROPIC_API_KEY=

# Billing (Stripe) — all server-side secrets, never expose to the browser:
#   STRIPE_SECRET_KEY=            # sk_live_... / sk_test_...
#   STRIPE_WEBHOOK_SECRET=        # whsec_... (from the webhook endpoint you create)
#   STRIPE_PRICE_PRO=             # price_... (the recurring price for the Pro plan)
# Service-role key for webhook writes that have no user session (KEEP SECRET —
# it bypasses row-level security). Supabase dashboard → Project Settings → API.
#   SUPABASE_SERVICE_ROLE_KEY=
