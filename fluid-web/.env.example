# Copy to .env.local for local development.
#
# Phase 2 — auth + persistence (Supabase). These match the variables the
# Supabase↔Vercel integration provisions. Both are safe to expose to the
# browser (project URL + publishable key); row-level security protects data.
# Find them in the Supabase dashboard under Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Older projects may use this name instead; the app accepts either:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Phase 3 — real generation (server-side only, never expose to the browser):
#   ANTHROPIC_API_KEY=
